<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Mode"
        Height="640" Width="1120"
        MinHeight="540" MinWidth="950"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryColor" Color="#6366F1"/>
        <SolidColorBrush x:Key="PrimaryHover" Color="#4F46E5"/>
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <!-- Theme-aware brushes (swapped at runtime) -->
        <SolidColorBrush x:Key="WindowBg" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="BgCard" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="ItemBg" Color="#F9FAFB"/>
        <SolidColorBrush x:Key="BtnSecondaryBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BtnSecondaryFg" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#1F2937"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#6B7280"/>
        <SolidColorBrush x:Key="BorderColor" Color="#E5E7EB"/>

        <!-- Styles -->
        <Style TargetType="Button" x:Key="PrimaryBtn">
            <Setter Property="Background" Value="{StaticResource PrimaryColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="DangerBtn" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="{StaticResource DangerColor}"/>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryBtn">
            <Setter Property="Background" Value="{DynamicResource BtnSecondaryBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource BtnSecondaryFg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource BgCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🎯" FontSize="32" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Focus Mode" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="StatusLabel" Text="Ready to focus"
                                   FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Timer -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="TimerText" Text="00:00:00"
                               FontSize="42" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}"
                               FontFamily="Consolas" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TimerSubtext" Text=""
                               FontSize="12" Foreground="{DynamicResource TextSecondary}"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock x:Name="CurrentTaskLabel" Text=""
                               FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryColor}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                </StackPanel>

                <!-- Stats + Gamification -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <!-- Stats row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock x:Name="StatsText" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextAlignment="Right" Margin="0,0,10,0"/>
                        <Button x:Name="LangBtn" Content="中/EN"
                                Style="{StaticResource SecondaryBtn}"
                                Click="LangBtn_Click"
                                FontSize="11" Padding="8,4"
                                ToolTip="Switch Language / 切换语言"/>
                        <Button x:Name="DarkModeBtn" Content="🌙"
                                Style="{StaticResource SecondaryBtn}"
                                Click="DarkModeBtn_Click"
                                FontSize="11" Padding="8,4" Margin="4,0,0,0"
                                ToolTip="Toggle dark mode"/>
                    </StackPanel>
                    <!-- Level + Streak + Achievements row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,0,0">
                        <TextBlock x:Name="StreakText" FontSize="12" Foreground="#F59E0B"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="AchievementsText" FontSize="12" Foreground="#8B5CF6"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="LevelText" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryColor}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- Level progress bar -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,2,0,0">
                        <ProgressBar x:Name="LevelProgressBar"
                                     Width="100" Height="6"
                                     Foreground="{StaticResource PrimaryColor}"
                                     Background="{DynamicResource BorderColor}"
                                     BorderThickness="0"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="LevelProgressText" FontSize="10"
                                   Foreground="{DynamicResource TextSecondary}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="310"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Whitelist + Todo -->
            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- App Whitelist Card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Style="{StaticResource SectionTitle}"
                                       x:Name="AppWhitelistTitle" Text="Application Whitelist"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="AddAppBtn" Content="+ Add App"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="AddAppBtn_Click"
                                        FontSize="12" Padding="10,6"/>
                                <Button x:Name="RemoveAppBtn" Content="- Remove"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="RemoveAppBtn_Click"
                                        FontSize="12" Padding="10,6" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" Margin="0,8,0,0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AppWhitelistList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8" Margin="0,0,0,4"
                                                Background="{DynamicResource ItemBg}" CornerRadius="6"
                                                BorderBrush="{DynamicResource BorderColor}" BorderThickness="0.5">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Center" Margin="0,0,8,0"/>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource TextSecondary}">
                                                        <Run Text="{Binding ProcessName, StringFormat='{}{0}.exe'}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <TextBlock Grid.Column="2"
                                                           Text="🌐" FontSize="16"
                                                           Visibility="{Binding IsBrowser, Converter={StaticResource BoolToVis}}"
                                                           VerticalAlignment="Center"
                                                           ToolTip="Browser: URL whitelist applies"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Todo List Card -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,4,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}"
                                   x:Name="TodoTitle" Text="Tasks"/>

                        <!-- Input row: textbox + type selector + add button -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <TextBox x:Name="NewTaskBox" FontSize="12" Padding="8,6"
                                         Width="200" VerticalContentAlignment="Center"
                                         KeyDown="NewTaskBox_KeyDown"/>
                                <Button x:Name="AddTaskBtn" Content="+ Add" Style="{StaticResource SecondaryBtn}"
                                        Click="AddTaskBtn_Click"
                                        FontSize="12" Padding="10,6" Margin="6,0,0,0"/>
                            </StackPanel>

                            <!-- Type selector -->
                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                <Button x:Name="ShortTermBtn" Content="Short" Tag="ShortTerm"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="TaskTypeBtn_Click"
                                        FontSize="10" Padding="6,3" Margin="0,0,3,0"/>
                                <Button x:Name="DailyBtn" Content="🔄 Daily" Tag="Daily"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="TaskTypeBtn_Click"
                                        FontSize="10" Padding="6,3" Margin="0,0,3,0"/>
                                <Button x:Name="LongTermBtn" Content="🎯 Long" Tag="LongTerm"
                                        Style="{StaticResource SecondaryBtn}"
                                        Click="TaskTypeBtn_Click"
                                        FontSize="10" Padding="6,3"/>
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="TodoList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="6,4" Margin="0,0,0,2"
                                                Background="{DynamicResource ItemBg}" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Type icon -->
                                                <TextBlock Grid.Column="0" Text="{Binding TypeIcon}"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           Margin="0,0,3,0"/>
                                                <CheckBox Grid.Column="1"
                                                          IsChecked="{Binding IsCompleted}"
                                                          Checked="TaskCheckBox_Changed"
                                                          Unchecked="TaskCheckBox_Changed"
                                                          VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock FontSize="13" Foreground="{DynamicResource TextPrimary}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Text}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <!-- Finish button (LongTerm only) -->
                                                <Button Grid.Column="3" Content="✓ Done"
                                                        FontSize="9" Padding="5,2"
                                                        Margin="4,0,0,0"
                                                        Click="FinishTaskBtn_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="Permanently finish this long-term task">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryBtn}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Type}" Value="LongTerm">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="ShortTerm">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Type}" Value="Daily">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                                <Button Grid.Column="4" Content="✕"
                                                        Style="{StaticResource SecondaryBtn}"
                                                        FontSize="10" Padding="4,2"
                                                        Margin="4,0,0,0"
                                                        Click="DeleteTaskBtn_Click"
                                                        Tag="{Binding}" ToolTip="Delete task"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Archive toggle + list -->
                        <StackPanel Grid.Row="3" Margin="0,8,0,0">
                            <Button x:Name="ArchiveToggleBtn" Content="Archive (0)"
                                    Style="{StaticResource SecondaryBtn}"
                                    Click="ArchiveToggleBtn_Click"
                                    FontSize="11" Padding="8,4"
                                    HorizontalAlignment="Left"/>
                            <ItemsControl x:Name="ArchiveList" Visibility="Collapsed"
                                          Margin="0,4,0,0" MaxHeight="120">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="4,3" Margin="0,0,0,2"
                                                Background="{DynamicResource ItemBg}" CornerRadius="3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="✅" FontSize="11"
                                                           VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Text}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextSecondary}"
                                                           TextDecorations="Strikethrough"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Middle: Radar Chart + Abilities -->
            <Grid Grid.Column="1" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Radar Chart Card -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,4">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}"
                                   x:Name="RadarTitle" Text="Stats" Margin="0,0,0,8"/>
                        <Canvas x:Name="RadarCanvas" Width="200" Height="200"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Ability Editor Card -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,4,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}"
                                   x:Name="AbilityEditorTitle" Text="Abilities" Margin="0,0,0,6"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="NewAbilityBox" FontSize="11" Padding="6,4"
                                     Width="100" VerticalContentAlignment="Center"
                                     KeyDown="NewAbilityBox_KeyDown"/>
                            <Button Content="+ Add" Style="{StaticResource SecondaryBtn}"
                                    Click="AddAbilityBtn_Click"
                                    FontSize="11" Padding="8,4" Margin="4,0,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="AbilityList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="5,3" Margin="0,0,0,2"
                                                Background="{DynamicResource ItemBg}" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Icon}"
                                                           FontSize="12" VerticalAlignment="Center"
                                                           Margin="0,0,4,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                               Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock FontSize="10"
                                                               Foreground="{DynamicResource TextSecondary}">
                                                        <Run Text="{Binding Points, StringFormat='{}Points: {0}'}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="+"
                                                        Style="{StaticResource SecondaryBtn}"
                                                        FontSize="9" Padding="4,1"
                                                        Click="AbilityAddPointBtn_Click"
                                                        Tag="{Binding}"/>
                                                <Button Grid.Column="3" Content="✕"
                                                        Style="{StaticResource SecondaryBtn}"
                                                        FontSize="9" Padding="4,1"
                                                        Margin="2,0,0,0"
                                                        Click="DeleteAbilityBtn_Click"
                                                        Tag="{Binding}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right: URL whitelist + Controls -->
            <Grid Grid.Column="2" Margin="8,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- URL Whitelist -->
                <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}"
                                   x:Name="UrlWhitelistTitle" Text="URL Whitelist"/>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBox x:Name="NewUrlBox" FontSize="12" Padding="8,6"
                                     Width="160" VerticalContentAlignment="Center"/>
                            <Button Content="+ Add" Style="{StaticResource SecondaryBtn}"
                                    Click="AddUrlBtn_Click"
                                    FontSize="12" Padding="10,6" Margin="6,0,0,0"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" MaxHeight="180" VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="UrlWhitelistList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,6" Margin="0,0,0,2"
                                                Background="{DynamicResource ItemBg}" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsEnabled}"
                                                          VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Pattern}"
                                                               FontSize="13" Foreground="{DynamicResource TextPrimary}"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                                               Visibility="{Binding Description, Converter={StaticResource StringToVis}}"/>
                                                </StackPanel>
                                                <Button Grid.Column="2" Content="▶"
                                                        Style="{StaticResource SecondaryBtn}"
                                                        FontSize="9" Padding="4,2"
                                                        Click="OpenUrlInChrome_Click"
                                                        Tag="{Binding}" ToolTip="Open in Chrome"/>
                                                <Button Grid.Column="3" Content="✕"
                                                        Style="{StaticResource SecondaryBtn}"
                                                        FontSize="10" Padding="4,2"
                                                        Margin="4,0,0,0"
                                                        Click="RemoveUrlBtn_Click"
                                                        Tag="{Binding}" ToolTip="Remove"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Settings -->
                <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" x:Name="SettingsTitle" Text="Settings"/>

                        <!-- Focus Duration -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="DurationLabel"
                                       Text="Focus Duration:"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" x:Name="DurationText"
                                       Text="25 min" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                        </Grid>
                        <Slider x:Name="DurationSlider" Minimum="5" Maximum="120"
                                Value="25" TickFrequency="5" IsSnapToTickEnabled="True"
                                Margin="0,0,0,10"/>

                        <!-- Enforce URL whitelist -->
                        <CheckBox x:Name="EnforceUrlCheck" Content="Enforce URL whitelist for browsers"
                                  IsChecked="True" FontSize="13"
                                  Foreground="{DynamicResource TextSecondary}"
                                  Margin="0,0,0,8"/>

                        <!-- Start with Windows -->
                        <CheckBox x:Name="AutoStartCheck" Content="Start with Windows"
                                  IsChecked="False" FontSize="13"
                                  Foreground="{DynamicResource TextSecondary}"
                                  Margin="0,0,0,10"/>

                        <!-- Monitor interval info -->
                        <TextBlock FontSize="11" Foreground="{DynamicResource TextSecondary}"
                                   Text="Checks active window every 1.5 seconds. Only enforces when focus mode is active."/>
                    </StackPanel>
                </Border>

                <!-- Controls -->
                <Border Grid.Row="2" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartBtn" Grid.Column="0"
                                Content="▶ Start Focus"
                                Style="{StaticResource PrimaryBtn}"
                                Click="StartBtn_Click"
                                Margin="0,0,6,0"/>
                        <Button x:Name="StopBtn" Grid.Column="1"
                                Content="⏹ Stop"
                                Style="{StaticResource DangerBtn}"
                                Click="StopBtn_Click"
                                IsEnabled="False"
                                Margin="6,0,0,0"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="2" Margin="0,12,0,0"
                Background="{DynamicResource BgCard}" CornerRadius="8"
                BorderBrush="{DynamicResource BorderColor}" BorderThickness="1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Ellipse Grid.Column="0" x:Name="StatusDot"
                         Width="10" Height="10" Fill="#9CA3AF"
                         Margin="0,0,8,0"/>
                <TextBlock Grid.Column="1" x:Name="StatusBarText"
                           Text="Not monitoring — click Start to begin"
                           FontSize="12" Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" x:Name="ViolationCountLabel"
                           Text="" FontSize="12" Foreground="{StaticResource DangerColor}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
