<Window x:Class="WpfApp1.Views.ViolationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Focus Violation" Height="280" Width="480"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="#FEF3C7" CornerRadius="8" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Warning icon and title -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <TextBlock Text="⚠" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel>
                    <TextBlock x:Name="TitleText" Text="Non-whitelisted App Detected"
                               FontSize="18" FontWeight="Bold" Foreground="#92400E"/>
                    <TextBlock x:Name="SubtitleText" FontSize="13" Foreground="#78350F"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Details -->
            <Border Grid.Row="1" Background="#FFFBEB" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock x:Name="AppNameText" FontSize="15" FontWeight="SemiBold"
                               Foreground="#1F2937"/>
                    <TextBlock x:Name="DetailText" FontSize="12" Foreground="#6B7280"
                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Countdown -->
            <TextBlock Grid.Row="2" x:Name="CountdownText" FontSize="12"
                       Foreground="#9CA3AF" TextWrapping="Wrap"
                       Text="Auto-close in 15 seconds..."/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="IgnoreBtn" Content="Ignore (1 min)" Click="IgnoreBtn_Click"
                        Background="#F3F4F6" Foreground="#374151" BorderBrush="#D1D5DB"/>
                <Button x:Name="AddWhitelistBtn" Content="Add to Whitelist" Click="AddWhitelistBtn_Click"
                        Background="#10B981" Foreground="White" BorderBrush="#059669"/>
                <Button x:Name="CloseAppBtn" Content="Close App" Click="CloseAppBtn_Click"
                        Background="#EF4444" Foreground="White" BorderBrush="#DC2626"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
