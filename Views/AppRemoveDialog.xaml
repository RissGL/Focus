<Window x:Class="WpfApp1.Views.AppRemoveDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Remove App"
        Height="320" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="PromptText"
                   Text="Select an app to remove:"
                   FontSize="14" FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <ListBox Grid.Row="1" x:Name="AppListBox"
                 DisplayMemberPath="DisplayText"
                 SelectionMode="Single"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="CancelBtn" Content="Cancel" Click="CancelBtn_Click"
                    Padding="14,6" Margin="0,0,8,0"/>
            <Button x:Name="RemoveBtn" Content="Remove" Click="RemoveBtn_Click"
                    Padding="14,6"
                    Background="#EF4444" Foreground="White"
                    BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
